---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Section from '../../components/Section.astro';
import Container from '../../components/Container.astro';
import Card from '../../components/Card.astro';
import Badge from '../../components/Badge.astro';
import Button from '../../components/Button.astro';
import CTABanner from '../../components/CTABanner.astro';

// External links
const ssrnUrl = '#'; // TODO: Replace with actual SSRN URL when available
const substackUrl = 'https://navvaidhyanathanatvysdomai.substack.com/';
const zenodoUrl = 'https://zenodo.org/records/19544419';

// Schema.org ScholarlyArticle structured data
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'ScholarlyArticle',
  name: 'The Economics of Entangled Time: Simultaneous Production-Consumption, Dark GDP, and the Macroeconomic Architecture of Algorithmic Monopsony',
  headline: 'Dark GDP: The Economics of Entangled Time',
  author: {
    '@type': 'Person',
    name: 'Nav Vaidhyanathan',
    url: 'https://vysdom.ai/about',
    affiliation: {
      '@type': 'Organization',
      name: 'Vysdom AI',
    },
  },
  datePublished: '2026-03-15',
  description: 'When you scroll a social media feed, you are simultaneously producing economic output — behavioral data that trains AI systems and generates hundreds of billions in advertising revenue. This production is uncompensated, unrecognized, and invisible to GDP. This paper formalizes the missing category.',
  url: 'https://vysdom.ai/research/dark-gdp',
  publisher: {
    '@type': 'Organization',
    name: 'Vysdom AI',
    url: 'https://vysdom.ai',
  },
  about: [
    'Dark GDP',
    'Entangled Time',
    'Algorithmic Monopsony',
    'Digital Labor',
    'Behavioral Data',
    'National Accounts',
  ],
  isPartOf: {
    '@type': 'CreativeWorkSeries',
    name: 'Vysdom AI Research',
  },
};

// Campaign structured data
const campaignSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'Dark GDP Campaign',
  description: 'Research campaign page for Dark GDP — the aggregate shadow value of unpriced behavioral data labor, invisible to the System of National Accounts.',
  url: 'https://vysdom.ai/research/dark-gdp',
  mainEntity: articleSchema,
};
---

<BaseLayout
  title="Dark GDP: The Economics of Entangled Time"
  description="You are an unpaid worker — and the world's accounting systems can't see it. Explore the research on Dark GDP: the hidden economy of behavioral data labor."
  ogImage="/images/campaigns/dark-gdp-og.png"
>
  <!-- Schema.org structured data -->
  <script type="application/ld+json" set:html={JSON.stringify(campaignSchema)} slot="head" />

  <!-- ===== HERO ===== -->
  <section class="relative overflow-hidden py-20 md:py-28 lg:py-36" id="hero">
    <!-- Decorative gradient orb -->
    <div
      class="pointer-events-none absolute -top-40 left-1/2 h-[600px] w-[600px] -translate-x-1/2
             rounded-full opacity-15 blur-[120px]
             gradient-hero"
      aria-hidden="true"
    ></div>

    <Container class="relative z-10">
      <div class="grid grid-cols-1 items-center gap-10 lg:grid-cols-5">
        <!-- Text column (spans 3) -->
        <div class="lg:col-span-3">
          <div class="hero-fade mb-5" style="opacity: 0; transform: translateY(1.5rem);">
            <Badge variant="brand">Economics · Research Campaign</Badge>
          </div>

          <h1
            class="hero-fade mb-5 font-heading text-4xl leading-tight tracking-tight md:text-5xl"
            style="opacity: 0; transform: translateY(1.5rem);"
          >
            You Are an Unpaid Worker
            <span class="gradient-text">&mdash; and the World&rsquo;s Accounting Systems Can&rsquo;t See It</span>
          </h1>

          <p
            class="hero-fade mb-8 max-w-xl text-base leading-relaxed text-text-secondary md:text-lg"
            style="opacity: 0; transform: translateY(1.5rem);"
          >
            When you scroll a social media feed, you are simultaneously producing a distinct economic output &mdash; behavioral data that trains AI systems and generates hundreds of billions in revenue. This production is uncompensated and invisible to GDP.
          </p>

          <div class="hero-fade flex flex-col gap-3 sm:flex-row" style="opacity: 0; transform: translateY(1.5rem);">
            <Button href={zenodoUrl} variant="primary" size="lg" id="hero-read-paper" target="_blank">
              Read the Full Paper
            </Button>
            <Button href={substackUrl} variant="secondary" size="lg" id="hero-substack" target="_blank">
              Read on Substack
            </Button>
          </div>
        </div>

        <!-- Visual accent column (spans 2) -->
        <div class="lg:col-span-2">
          <div class="hero-fade relative" style="opacity: 0; transform: translateY(1.5rem);">
            <img
              src="/images/campaigns/dark-gdp-hero.png"
              alt="Abstract visualization of behavioral data flowing from human silhouettes into algorithmic networks"
              class="rounded-2xl shadow-lg"
              width="600"
              height="600"
              loading="eager"
            />
          </div>
        </div>
      </div>
    </Container>
  </section>

  <!-- ===== THE PROBLEM: What GDP Misses ===== -->
  <Section background="alternate" id="the-problem">
    <Container>
      <div class="mx-auto mb-12 max-w-2xl text-center">
        <Badge variant="brand" class="mb-4">The Problem</Badge>
        <h2 class="mb-4 font-heading text-3xl leading-tight tracking-tight md:text-4xl">
          What GDP Misses
        </h2>
        <p class="mx-auto max-w-xl text-text-secondary text-base md:text-lg">
          The System of National Accounts classifies your screen time as idle leisure. The firms monetizing it disagree.
        </p>
      </div>

      <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
        <!-- Card 1: Screen time is classified as leisure -->
        <Card hover={false}>
          <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-brand-50 dark:bg-brand-500/10">
            <span class="text-2xl" aria-hidden="true">📱</span>
          </div>
          <h3 class="mb-2 font-heading text-xl leading-snug">
            Screen Time = &ldquo;Leisure&rdquo;
          </h3>
          <p class="text-sm text-text-secondary leading-relaxed">
            Every statistical agency on Earth classifies digital engagement as non-market leisure consumption. You&rsquo;re scrolling in a park, economically speaking.
          </p>
        </Card>

        <!-- Card 2: Behavioral data is a trillion-dollar input -->
        <Card hover={false}>
          <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-brand-50 dark:bg-brand-500/10">
            <span class="text-2xl" aria-hidden="true">📊</span>
          </div>
          <h3 class="mb-2 font-heading text-xl leading-snug">
            $1.3 Trillion in Monetized Data
          </h3>
          <p class="text-sm text-text-secondary leading-relaxed">
            Digital advertising ($680B), enterprise AI ($300–500B), and data brokerage ($250–350B) are all built on behavioral data generated during this &ldquo;leisure.&rdquo;
          </p>
        </Card>

        <!-- Card 3: No accounting system counts it -->
        <Card hover={false}>
          <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-brand-50 dark:bg-brand-500/10">
            <span class="text-2xl" aria-hidden="true">🔍</span>
          </div>
          <h3 class="mb-2 font-heading text-xl leading-snug">
            The Measurement Blind Spot
          </h3>
          <p class="text-sm text-text-secondary leading-relaxed">
            No minimum wage law covers this labor. No union bargains for it. The market that would constrain extraction does not exist.
          </p>
        </Card>
      </div>

      <!-- Infographic -->
      <div class="mt-12 flex justify-center">
        <img
          src="/images/campaigns/dark-gdp-infographic.png"
          alt="Infographic: What GDP Misses — Measured economy (wages, goods, services) vs. Unmeasured Dark GDP (screen time, behavioral data, AI training)"
          class="w-full max-w-3xl rounded-2xl border border-border-subtle shadow-md"
          width="960"
          height="540"
          loading="lazy"
        />
      </div>
    </Container>
  </Section>

  <!-- ===== THE FRAMEWORK: Entangled Time ===== -->
  <Section id="the-framework">
    <Container>
      <div class="mx-auto mb-12 max-w-2xl text-center">
        <Badge variant="brand" class="mb-4">The Framework</Badge>
        <h2 class="mb-4 font-heading text-3xl leading-tight tracking-tight md:text-4xl">
          Entangled Time: A Third Kind of Time
        </h2>
        <p class="mx-auto max-w-xl text-text-secondary text-base md:text-lg">
          Since 1965, economics has partitioned time into two states: work and leisure. The digital economy created a third.
        </p>
      </div>

      <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
        <!-- Step 1: Becker's Partition -->
        <Card hover={false}>
          <div class="mb-3 flex items-center gap-2">
            <span class="flex h-8 w-8 items-center justify-center rounded-full bg-brand-50 font-mono text-sm font-bold text-brand-600 dark:bg-brand-500/10 dark:text-brand-400">1</span>
            <Badge variant="outline">Classical Model</Badge>
          </div>
          <h3 class="mb-2 font-heading text-xl leading-snug">
            Becker&rsquo;s Two-State Partition
          </h3>
          <p class="mb-4 text-sm text-text-secondary leading-relaxed">
            Gary Becker (1965): all time is either <strong>work</strong> (selling time for wages) or <strong>consumption</strong> (enjoying goods). These states are mutually exclusive. GDP is built on this partition.
          </p>
          <div class="rounded-lg bg-surface-secondary p-3 dark:bg-surface-tertiary">
            <code class="font-mono text-xs text-text-secondary">
              T̄ = T<sub>w</sub> + T<sub>c</sub>&ensp; where &ensp;T<sub>w</sub> ∩ T<sub>c</sub> = ∅
            </code>
          </div>
        </Card>

        <!-- Step 2: Entangled Time -->
        <Card hover={false}>
          <div class="mb-3 flex items-center gap-2">
            <span class="flex h-8 w-8 items-center justify-center rounded-full bg-brand-50 font-mono text-sm font-bold text-brand-600 dark:bg-brand-500/10 dark:text-brand-400">2</span>
            <Badge variant="brand">New Model</Badge>
          </div>
          <h3 class="mb-2 font-heading text-xl leading-snug">
            Simultaneous Production-Consumption
          </h3>
          <p class="mb-4 text-sm text-text-secondary leading-relaxed">
            Digital engagement is <strong>both</strong> consumption (you enjoy the content) <strong>and</strong> production (your behavioral data trains AI systems). This <em>Entangled Time</em> is the missing third state.
          </p>
          <div class="rounded-lg bg-surface-secondary p-3 dark:bg-surface-tertiary">
            <code class="font-mono text-xs text-text-secondary">
              T<sub>w</sub> + T<sub>p</sub> + T<sub>e</sub> + B<sub>min</sub> = T̄
            </code>
          </div>
        </Card>

        <!-- Step 3: The Autocatalytic Loop -->
        <Card hover={false}>
          <div class="mb-3 flex items-center gap-2">
            <span class="flex h-8 w-8 items-center justify-center rounded-full bg-brand-50 font-mono text-sm font-bold text-brand-600 dark:bg-brand-500/10 dark:text-brand-400">3</span>
            <Badge variant="outline">Feedback Loop</Badge>
          </div>
          <h3 class="mb-2 font-heading text-xl leading-snug">
            The Autocatalytic Loop
          </h3>
          <p class="mb-4 text-sm text-text-secondary leading-relaxed">
            Zero-cost data labor → firms reinvest in better algorithms → higher engagement → more data → the loop closes. The firm&rsquo;s capacity is ultimately bounded by the total waking hours of the human species.
          </p>
          <div class="rounded-lg bg-surface-secondary p-3 dark:bg-surface-tertiary">
            <code class="font-mono text-xs text-text-secondary">
              K<sub>d</sub><sup>ss</sup> = λN(T̄ − B<sub>min</sub>) / δ<sub>d</sub>
            </code>
          </div>
        </Card>
      </div>
    </Container>
  </Section>

  <!-- ===== KEY FINDINGS ===== -->
  <Section background="alternate" id="key-findings">
    <Container>
      <div class="mx-auto mb-12 max-w-2xl text-center">
        <Badge variant="brand" class="mb-4">Key Findings</Badge>
        <h2 class="mb-4 font-heading text-3xl leading-tight tracking-tight md:text-4xl">
          The Numbers
        </h2>
        <p class="mx-auto max-w-xl text-text-secondary text-base md:text-lg">
          Calibrated estimates from publicly available data (2024–2025).
        </p>
      </div>

      <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
        <!-- Finding 1 -->
        <Card hover={false}>
          <div class="flex items-start gap-4">
            <div class="shrink-0">
              <span class="font-mono text-3xl font-bold text-brand-500 dark:text-brand-400">13T</span>
              <p class="text-xs text-text-tertiary">hours/year</p>
            </div>
            <div>
              <h3 class="mb-1 font-heading text-lg leading-snug">
                Unpaid Data Labor
              </h3>
              <p class="text-sm text-text-secondary leading-relaxed">
                5.5 billion connected people × 6.5 hours/day of screen time = 13 trillion hours of Entangled Time per year. That is <strong>4× the total formal labor force.</strong>
              </p>
            </div>
          </div>
        </Card>

        <!-- Finding 2 -->
        <Card hover={false}>
          <div class="flex items-start gap-4">
            <div class="shrink-0">
              <span class="font-mono text-3xl font-bold text-brand-500 dark:text-brand-400">$1.3T</span>
              <p class="text-xs text-text-tertiary">per year</p>
            </div>
            <div>
              <h3 class="mb-1 font-heading text-lg leading-snug">
                Conservative Dark GDP
              </h3>
              <p class="text-sm text-text-secondary leading-relaxed">
                Using only directly observable revenue channels (advertising, enterprise AI, data brokerage). The implied shadow wage: roughly <strong>$0.10/hour</strong> — below every minimum wage on Earth.
              </p>
            </div>
          </div>
        </Card>

        <!-- Finding 3 -->
        <Card hover={false}>
          <div class="flex items-start gap-4">
            <div class="shrink-0">
              <span class="font-mono text-3xl font-bold text-brand-500 dark:text-brand-400">$10–15T</span>
              <p class="text-xs text-text-tertiary">adjusted estimate</p>
            </div>
            <div>
              <h3 class="mb-1 font-heading text-lg leading-snug">
                Full Measurement Correction
              </h3>
              <p class="text-sm text-text-secondary leading-relaxed">
                Including unmeasured channels (foundation model training, implicit RLHF, background data collection, biometric bandwidth), the adjusted estimate recovers the <strong>majority of the global labor share decline.</strong>
              </p>
            </div>
          </div>
        </Card>

        <!-- Finding 4 -->
        <Card hover={false}>
          <div class="flex items-start gap-4">
            <div class="shrink-0">
              <span class="font-mono text-3xl font-bold text-brand-500 dark:text-brand-400">$0</span>
              <p class="text-xs text-text-tertiary">optimal wage</p>
            </div>
            <div>
              <h3 class="mb-1 font-heading text-lg leading-snug">
                Zero-Wage Equilibrium
              </h3>
              <p class="text-sm text-text-secondary leading-relaxed">
                The profit-maximizing fiat wage for data labor is exactly zero — not from greed, but from <strong>market structure</strong>. The labor supply is perfectly inelastic at the biological maximum. The firm cannot increase data by paying more.
              </p>
            </div>
          </div>
        </Card>
      </div>
    </Container>
  </Section>

  <!-- ===== POLICY IMPLICATIONS ===== -->
  <Section id="policy-implications">
    <Container>
      <div class="mx-auto mb-12 max-w-2xl text-center">
        <Badge variant="brand" class="mb-4">Policy Implications</Badge>
        <h2 class="mb-4 font-heading text-3xl leading-tight tracking-tight md:text-4xl">
          Three Institutional Redesigns
        </h2>
        <p class="mx-auto max-w-xl text-text-secondary text-base md:text-lg">
          Not utopian fantasies — specific policy instruments grounded in the model&rsquo;s equilibrium structure, each with precedent in existing regulatory frameworks.
        </p>
      </div>

      <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
        <!-- Proposal 1 -->
        <Card hover={false}>
          <Badge variant="brand" class="mb-3">Antitrust</Badge>
          <h3 class="mb-2 font-heading text-xl leading-snug">
            Algorithmic Monopsony Standard
          </h3>
          <p class="text-sm text-text-secondary leading-relaxed">
            Replace the Consumer Welfare Standard — which cannot address zero-price platforms — with an upstream focus: &ldquo;Is the data laborer being underpaid?&rdquo; instead of &ldquo;Is the consumer being overcharged?&rdquo;
          </p>
        </Card>

        <!-- Proposal 2 -->
        <Card hover={false}>
          <Badge variant="brand" class="mb-3">Taxation</Badge>
          <h3 class="mb-2 font-heading text-xl leading-snug">
            Algorithmic Severance Tax
          </h3>
          <p class="text-sm text-text-secondary leading-relaxed">
            A Pigouvian levy on extracted data capital, calibrated to the shadow wage. Because labor supply is nearly perfectly inelastic, deadweight loss is correspondingly modest — a rare case of an efficient Pigouvian tax.
          </p>
        </Card>

        <!-- Proposal 3 -->
        <Card hover={false}>
          <Badge variant="brand" class="mb-3">Human Capital</Badge>
          <h3 class="mb-2 font-heading text-xl leading-snug">
            Cognitive Depreciation Allowance
          </h3>
          <p class="text-sm text-text-secondary leading-relaxed">
            Explicit compensation for the endogenous depreciation of autonomous cognitive capacity caused by sustained interface use — funded by Severance Tax revenue. Not UBI. A depreciation allowance for human capital.
          </p>
        </Card>
      </div>

      <!-- Time constraint callout -->
      <div class="mx-auto mt-10 max-w-2xl rounded-xl border border-warning/30 bg-warning/5 p-6">
        <p class="text-sm text-text-secondary leading-relaxed">
          <strong class="text-text-primary">The window is closing.</strong> The model proves these interventions are effective only during the transition — before cognitive capital depreciates irreversibly. After the transition, the equilibrium is a trap. Each year of inaction narrows the window.
        </p>
      </div>
    </Container>
  </Section>

  <!-- ===== READ THE FULL PAPER ===== -->
  <Section background="alternate" id="read-the-paper">
    <Container>
      <div class="mx-auto max-w-2xl text-center">
        <Badge variant="brand" class="mb-4">The Full Paper</Badge>
        <h2 class="mb-4 font-heading text-3xl leading-tight tracking-tight md:text-4xl">
          Read the Research
        </h2>
        <p class="mx-auto mb-8 max-w-xl text-text-secondary text-base md:text-lg">
          &ldquo;The Economics of Entangled Time: Simultaneous Production-Consumption, Dark GDP, and the Macroeconomic Architecture of Algorithmic Monopsony&rdquo;
        </p>

        <div class="flex flex-col items-center justify-center gap-4 sm:flex-row">
          <Button href={zenodoUrl} variant="primary" size="lg" id="cta-zenodo" target="_blank">
            Zenodo (Open Access)
          </Button>
          <Button href={substackUrl} variant="secondary" size="lg" id="cta-substack" target="_blank">
            Substack (Plain Language)
          </Button>
        </div>

        <p class="mt-6 text-xs text-text-tertiary">
          Working paper · March 2026 · Nav Vaidhyanathan
        </p>
      </div>
    </Container>
  </Section>

  <!-- ===== CTA BANNER ===== -->
  <CTABanner
    title="Discuss This Research"
    description="Interested in the policy implications of Dark GDP? Exploring the economics of digital labor for your organization? Let's talk."
    primaryCTA={{ label: 'Book a Discovery Call', href: '/contact' }}
    secondaryCTA={{ label: 'Follow on Substack', href: substackUrl, external: true }}
    gradient="cta"
  />
</BaseLayout>

<!-- Hero fade-in animation -->
<script>
  function showHeroElements() {
    document.querySelectorAll('.hero-fade').forEach((el) => {
      const htmlEl = el as HTMLElement;
      htmlEl.style.opacity = '1';
      htmlEl.style.transform = 'translateY(0)';
      htmlEl.style.transition = 'opacity 0.6s ease, transform 0.6s ease';
    });
  }

  // Safety fallback
  const heroFallback = setTimeout(showHeroElements, 2000);

  async function initHeroFadeIn() {
    try {
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        clearTimeout(heroFallback);
        showHeroElements();
        return;
      }

      const { gsap } = await import('gsap');
      clearTimeout(heroFallback);

      const els = document.querySelectorAll('.hero-fade');
      gsap.to(els, {
        opacity: 1,
        y: 0,
        duration: 0.7,
        stagger: 0.12,
        ease: 'power3.out',
      });
    } catch {
      clearTimeout(heroFallback);
      showHeroElements();
    }
  }

  initHeroFadeIn();
</script>
