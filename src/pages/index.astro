---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/HeroSection.astro';
import Section from '../components/Section.astro';
import Container from '../components/Container.astro';
import Card from '../components/Card.astro';
import Badge from '../components/Badge.astro';
import Button from '../components/Button.astro';
import CTABanner from '../components/CTABanner.astro';
---

<BaseLayout
  title="Home"
  description="Vysdom AI — Research consulting, advanced analytics, and TDI tools for the modern enterprise. 17 years of quantitative finance expertise."
>
  <!-- Hero Section -->
  <HeroSection
    overline="Research · Consulting · Analytics"
    headline="Rigorous Theory, Real-World Impact"
    subheadline="Research consulting and advanced analytical tools — bridging 17 years of quantitative finance expertise with actionable insights for the modern enterprise."
    primaryCTA={{ label: 'Explore Research', href: '/research' }}
    secondaryCTA={{ label: 'Book a Discovery Call', href: '/contact' }}
  />

  <!-- Featured Research Section -->
  <Section background="alternate" id="featured-research">
    <Container>
      <div class="mx-auto mb-12 max-w-2xl text-center">
        <Badge variant="brand" class="mb-4">Featured Research</Badge>
        <h2 class="mb-4 font-heading text-3xl leading-tight tracking-tight md:text-4xl">
          Shaping the Future of Economic Thought
        </h2>
        <p class="mx-auto max-w-xl text-text-secondary text-base md:text-lg">
          Original research at the intersection of quantum gravity, economics, and formal verification.
        </p>
      </div>

      <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
        <Card>
          <div class="mb-3 flex gap-2">
            <Badge>Quantum Gravity</Badge>
            <Badge variant="outline">2026</Badge>
          </div>
          <h3 class="mb-2 font-heading text-xl leading-snug">
            Tensor-Driven Inertia Framework
          </h3>
          <p class="text-sm text-text-secondary leading-relaxed">
            A novel approach to unifying general relativity with quantum mechanics through tensor field interactions in curved spacetime.
          </p>
        </Card>

        <Card>
          <div class="mb-3 flex gap-2">
            <Badge>Economics</Badge>
            <Badge variant="outline">2026</Badge>
          </div>
          <h3 class="mb-2 font-heading text-xl leading-snug">
            Dark GDP: Economics of Entangled Time
          </h3>
          <p class="text-sm text-text-secondary leading-relaxed">
            Modeling economic value generated by gig workers and platform laborers operating across multiple temporal contracts simultaneously.
          </p>
        </Card>

        <Card>
          <div class="mb-3 flex gap-2">
            <Badge>Formal Verification</Badge>
            <Badge variant="outline">2026</Badge>
          </div>
          <h3 class="mb-2 font-heading text-xl leading-snug">
            Lean 4 Discovery Engine
          </h3>
          <p class="text-sm text-text-secondary leading-relaxed">
            Compiler-verified mathematical proofs for physical theories — ensuring every equation is machine-checked before publication.
          </p>
        </Card>
      </div>

      <div class="mt-10 text-center">
        <Button href="/research" variant="secondary">
          View All Research →
        </Button>
      </div>
    </Container>
  </Section>

  <!-- Value Proposition Section -->
  <Section id="value-proposition">
    <Container>
      <div class="grid grid-cols-1 items-center gap-12 lg:grid-cols-2">
        <div>
          <Badge variant="brand" class="mb-4">Why Vysdom</Badge>
          <h2 class="mb-6 font-heading text-3xl leading-tight tracking-tight md:text-4xl">
            Where Academic Rigor Meets Industry Expertise
          </h2>
          <p class="mb-6 text-text-secondary leading-relaxed">
            With 17 years in quantitative finance and a deep commitment to mathematical precision, Vysdom AI delivers research consulting that doesn&rsquo;t cut corners. Every analysis is backed by formal verification and reproducible methodology.
          </p>
          <div class="space-y-4">
            <div class="flex items-start gap-3">
              <div class="mt-1 flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-brand-50 dark:bg-brand-500/10">
                <div class="h-1.5 w-1.5 rounded-full bg-brand-500"></div>
              </div>
              <p class="text-sm text-text-secondary">
                <strong class="text-text-primary">Compiler-verified mathematics</strong> — equations checked by Lean 4 before they reach the page
              </p>
            </div>
            <div class="flex items-start gap-3">
              <div class="mt-1 flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-brand-50 dark:bg-brand-500/10">
                <div class="h-1.5 w-1.5 rounded-full bg-brand-500"></div>
              </div>
              <p class="text-sm text-text-secondary">
                <strong class="text-text-primary">Cross-domain synthesis</strong> — connecting insights from physics, economics, and engineering
              </p>
            </div>
            <div class="flex items-start gap-3">
              <div class="mt-1 flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-brand-50 dark:bg-brand-500/10">
                <div class="h-1.5 w-1.5 rounded-full bg-brand-500"></div>
              </div>
              <p class="text-sm text-text-secondary">
                <strong class="text-text-primary">Reproducible methodology</strong> — open research workflows and transparent analytical pipelines
              </p>
            </div>
          </div>
        </div>

        <div class="flex items-center justify-center">
          <div class="relative">
            <!-- Decorative card stack -->
            <div class="absolute -top-4 -left-4 h-full w-full rounded-2xl border border-border-subtle bg-surface-secondary opacity-50"></div>
            <Card hover={false} class="relative">
              <div class="space-y-4 p-2">
                <div class="flex items-center gap-3">
                  <div class="h-10 w-10 rounded-xl gradient-hero flex items-center justify-center text-white font-heading text-lg">
                    V
                  </div>
                  <div>
                    <p class="font-medium text-text-primary text-sm">Vysdom AI</p>
                    <p class="text-xs text-text-tertiary">Research & Consulting</p>
                  </div>
                </div>
                <div class="space-y-2 border-t border-border-subtle pt-4">
                  <div class="flex items-center justify-between text-xs">
                    <span class="text-text-tertiary">Research Papers</span>
                    <span class="font-mono text-text-primary">12</span>
                  </div>
                  <div class="flex items-center justify-between text-xs">
                    <span class="text-text-tertiary">Formal Proofs</span>
                    <span class="font-mono text-text-primary">47</span>
                  </div>
                  <div class="flex items-center justify-between text-xs">
                    <span class="text-text-tertiary">Compiler Verified</span>
                    <span class="font-mono text-success">100%</span>
                  </div>
                </div>
              </div>
            </Card>
          </div>
        </div>
      </div>
    </Container>
  </Section>

  <!-- CTA Banner -->
  <CTABanner
    title="Ready to Elevate Your Research?"
    description="Book a discovery call to discuss how rigorous methodology can drive better outcomes for your organization."
    primaryCTA={{ label: 'Book a Discovery Call', href: '/contact' }}
    secondaryCTA={{ label: 'Download Research Brief', href: '/research' }}
    gradient="cta"
  />
</BaseLayout>
