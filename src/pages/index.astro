---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/HeroSection.astro';
import Section from '../components/Section.astro';
import Container from '../components/Container.astro';
import Card from '../components/Card.astro';
import Badge from '../components/Badge.astro';
import Button from '../components/Button.astro';
import CTABanner from '../components/CTABanner.astro';

import { getCollection } from 'astro:content';

// Fetch published research entries, sorted by date (newest first)
const allResearch = (await getCollection('research'))
  .filter((entry) => !entry.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const featuredResearch = allResearch.slice(0, 3);

// Domain badge color mapping
const domainColors: Record<string, { variant: 'default' | 'brand' | 'success' | 'outline'; label: string }> = {
  physics: { variant: 'brand', label: 'Physics' },
  economics: { variant: 'default', label: 'Economics' },
};

// Schema.org Organization structured data
const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Vysdom AI',
  url: 'https://vysdom.ai',
  logo: 'https://vysdom.ai/logo.svg',
  description: 'Research consulting and advanced analytical tools — bridging rigorous theory with real-world impact.',
  founder: {
    '@type': 'Person',
    name: 'Nav Vaidhyanathan',
    url: 'https://vysdom.ai/about',
  },
  sameAs: [
    'https://www.linkedin.com/in/navvaidhyanathan/',
    'https://x.com/NavVAtVysdomAI',
    'https://navvaidhyanathanatvysdomai.substack.com/',
  ],
};
---

<BaseLayout
  title="Home"
  description="Vysdom AI — Research consulting, advanced analytics, and TDI tools for the modern enterprise. 17 years of quantitative finance expertise."
  ogImage="/og-home.png"
>
  <!-- Schema.org Organization -->
  <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} slot="head" />

  <!-- Hero Section -->
  <HeroSection
    overline="Research · Consulting · Analytics"
    headline="Rigorous Theory, Real-World Impact"
    subheadline="Research consulting and advanced analytical tools — bridging 17 years of quantitative finance expertise with actionable insights for the modern enterprise."
    primaryCTA={{ label: 'Explore Research', href: '/research' }}
    secondaryCTA={{ label: 'Book a Discovery Call', href: '/contact' }}
  />

  <!-- Featured Research Section (Dynamic) -->
  <Section background="alternate" id="featured-research">
    <Container>
      <div class="mx-auto mb-12 max-w-2xl text-center">
        <Badge variant="brand" class="mb-4">Featured Research</Badge>
        <h2 class="mb-4 font-heading text-3xl leading-tight tracking-tight md:text-4xl">
          Shaping the Future of Economic Thought
        </h2>
        <p class="mx-auto max-w-xl text-text-secondary text-base md:text-lg">
          Original research at the intersection of quantum gravity, economics, and formal verification.
        </p>
      </div>

      <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
        {featuredResearch.map((entry) => {
          const domain = domainColors[entry.data.domain] || { variant: 'default' as const, label: entry.data.domain };
          const year = entry.data.date.getFullYear().toString();
          return (
            <Card href={`/research/${entry.id}`}>
              <div class="mb-3 flex gap-2">
                <Badge variant={domain.variant}>{domain.label}</Badge>
                <Badge variant="outline">{year}</Badge>
                {entry.data.status === 'under-review' && (
                  <Badge variant="outline">Under Review</Badge>
                )}
              </div>
              <h3 class="mb-2 font-heading text-xl leading-snug">
                {entry.data.title}
              </h3>
              <p class="text-sm text-text-secondary leading-relaxed line-clamp-3">
                {entry.data.abstract}
              </p>
            </Card>
          );
        })}
      </div>

      <div class="mt-10 text-center">
        <Button href="/research" variant="secondary">
          View All Research →
        </Button>
      </div>
    </Container>
  </Section>

  <!-- Featured Campaign: Dark GDP -->
  <Section id="featured-campaign">
    <Container>
      <div class="grid grid-cols-1 items-center gap-8 lg:grid-cols-5">
        <!-- Text column (spans 3) -->
        <div class="lg:col-span-3">
          <Badge variant="brand" class="mb-4">Featured Campaign</Badge>
          <h2 class="mb-4 font-heading text-3xl leading-tight tracking-tight md:text-4xl">
            Dark GDP: The Hidden Economy of Unpaid Digital Labor
          </h2>
          <p class="mb-6 text-text-secondary leading-relaxed">
            When you scroll a social media feed, you are simultaneously producing economic output &mdash; behavioral data that trains AI systems and generates hundreds of billions in revenue. This labor is uncompensated and invisible to GDP. Our latest research formalizes the missing category.
          </p>
          <div class="flex flex-col gap-3 sm:flex-row">
            <Button href="/research/dark-gdp" variant="primary">
              Read the Research
            </Button>
            <Button href="https://navvaidhyanathanatvysdomai.substack.com/" variant="secondary" target="_blank">
              Follow on Substack
            </Button>
          </div>
        </div>

        <!-- Visual accent column (spans 2) -->
        <div class="lg:col-span-2">
          <div class="relative rounded-2xl border border-border-subtle bg-surface-secondary p-6 md:p-8">
            <div class="absolute top-0 left-0 h-full w-1 rounded-l-2xl gradient-hero"></div>
            <div class="space-y-4 pl-4">
              <div class="flex items-center justify-between text-sm">
                <span class="text-text-tertiary">Conservative Dark GDP</span>
                <span class="font-mono font-semibold text-brand-500 dark:text-brand-300">$1.3T/yr</span>
              </div>
              <div class="h-px bg-border-subtle"></div>
              <div class="flex items-center justify-between text-sm">
                <span class="text-text-tertiary">Unpaid Data Labor</span>
                <span class="font-mono font-semibold text-text-primary">13T hrs/yr</span>
              </div>
              <div class="h-px bg-border-subtle"></div>
              <div class="flex items-center justify-between text-sm">
                <span class="text-text-tertiary">Connected Population</span>
                <span class="font-mono font-semibold text-text-primary">5.5B</span>
              </div>
              <div class="h-px bg-border-subtle"></div>
              <div class="flex items-center justify-between text-sm">
                <span class="text-text-tertiary">Framework</span>
                <span class="font-mono font-semibold text-text-primary">Entangled Time</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </Container>
  </Section>

  <!-- Value Proposition Section -->
  <Section background="alternate" id="value-proposition">
    <Container>
      <div class="grid grid-cols-1 items-center gap-12 lg:grid-cols-2">
        <div>
          <Badge variant="brand" class="mb-4">Why Vysdom</Badge>
          <h2 class="mb-6 font-heading text-3xl leading-tight tracking-tight md:text-4xl">
            Where Academic Rigor Meets Industry Expertise
          </h2>
          <p class="mb-6 text-text-secondary leading-relaxed">
            With 17 years in quantitative finance and a deep commitment to mathematical precision, Vysdom AI delivers research consulting that doesn&rsquo;t cut corners. Every analysis is backed by formal verification and reproducible methodology.
          </p>
          <div class="space-y-4">
            <div class="flex items-start gap-3">
              <div class="mt-1 flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-brand-50 dark:bg-brand-500/10">
                <div class="h-1.5 w-1.5 rounded-full bg-brand-500"></div>
              </div>
              <p class="text-sm text-text-secondary">
                <strong class="text-text-primary">Compiler-verified mathematics</strong> — equations checked by Lean 4 before they reach the page
              </p>
            </div>
            <div class="flex items-start gap-3">
              <div class="mt-1 flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-brand-50 dark:bg-brand-500/10">
                <div class="h-1.5 w-1.5 rounded-full bg-brand-500"></div>
              </div>
              <p class="text-sm text-text-secondary">
                <strong class="text-text-primary">Cross-domain synthesis</strong> — connecting insights from physics, economics, and engineering
              </p>
            </div>
            <div class="flex items-start gap-3">
              <div class="mt-1 flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-brand-50 dark:bg-brand-500/10">
                <div class="h-1.5 w-1.5 rounded-full bg-brand-500"></div>
              </div>
              <p class="text-sm text-text-secondary">
                <strong class="text-text-primary">Reproducible methodology</strong> — open research workflows and transparent analytical pipelines
              </p>
            </div>
          </div>
        </div>

        <div class="flex items-center justify-center">
          <div class="relative">
            <!-- Decorative card stack -->
            <div class="absolute -top-4 -left-4 h-full w-full rounded-2xl border border-border-subtle bg-surface-secondary opacity-50"></div>
            <Card hover={false} class="relative">
              <div class="space-y-4 p-2">
                <div class="flex items-center gap-3">
                  <div class="flex items-center justify-center h-10 w-10 rounded-full bg-white border border-border-default shrink-0">
                    <img
                      src="/logo-mark-simple.svg"
                      alt=""
                      width="26"
                      height="26"
                      class="size-6.5"
                    />
                  </div>
                  <div>
                    <p class="font-medium text-text-primary text-sm">Vysdom AI</p>
                    <p class="text-xs text-text-tertiary">Research & Consulting</p>
                  </div>
                </div>
                <div class="space-y-2 border-t border-border-subtle pt-4">
                  <div class="flex items-center justify-between text-xs">
                    <span class="text-text-tertiary">Research Papers</span>
                    <span class="font-mono text-text-primary">{allResearch.length}</span>
                  </div>
                  <div class="flex items-center justify-between text-xs">
                    <span class="text-text-tertiary">Research Domains</span>
                    <span class="font-mono text-text-primary">2</span>
                  </div>
                  <div class="flex items-center justify-between text-xs">
                    <span class="text-text-tertiary">Formal Verification</span>
                    <span class="font-mono text-success">Active</span>
                  </div>
                </div>
              </div>
            </Card>
          </div>
        </div>
      </div>
    </Container>
  </Section>

  <!-- Testimonials (Placeholder — populated via /credibility-intake workflow) -->
  <Section id="testimonials">
    <Container>
      <div class="mx-auto max-w-2xl text-center">
        <Badge variant="brand" class="mb-4">Testimonials</Badge>
        <h2 class="mb-4 font-heading text-3xl leading-tight tracking-tight md:text-4xl">
          What Clients Say
        </h2>
        <p class="mx-auto max-w-xl text-text-tertiary text-sm leading-relaxed">
          Client testimonials will appear here as we build our public track record.
          Have we worked together?
          <a href="/contact" class="text-text-link hover:text-text-link-hover underline">Share your experience</a>.
        </p>
      </div>
    </Container>
  </Section>

  <!-- CTA Banner -->
  <CTABanner
    title="Ready to Elevate Your Research?"
    description="Book a discovery call to discuss how rigorous methodology can drive better outcomes for your organization."
    primaryCTA={{ label: 'Book a Discovery Call', href: '/contact' }}
    secondaryCTA={{ label: 'Download Research Brief', href: '/research' }}
    gradient="cta"
  />
</BaseLayout>

<style>
  /* Line clamp for abstract truncation */
  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
