---
/**
 * Button — Multi-variant button with hover animations.
 *
 * @prop variant - "primary" | "secondary" | "ghost"
 * @prop size - "sm" | "md" | "lg"
 * @prop href - If provided, renders as <a> instead of <button>
 * @prop class - Additional CSS classes
 * @prop type - Button type (only when not href)
 * @prop id - Unique ID for testing
 */
interface Props {
  variant?: 'primary' | 'secondary' | 'ghost';
  size?: 'sm' | 'md' | 'lg';
  href?: string;
  class?: string;
  type?: 'button' | 'submit' | 'reset';
  id?: string;
}

const {
  variant = 'primary',
  size = 'md',
  href,
  class: className = '',
  type = 'button',
  id,
} = Astro.props;

const baseClasses = [
  'inline-flex items-center justify-center gap-2',
  'font-body font-medium',
  'transition-all duration-200 ease-default',
  'focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-500',
  'disabled:opacity-50 disabled:cursor-not-allowed',
  'cursor-pointer',
];

const variantClasses: Record<string, string> = {
  primary: [
    'bg-brand-500 text-white',
    'hover:bg-brand-600 hover:shadow-md',
    'active:scale-[0.98]',
  ].join(' '),
  secondary: [
    'border border-border-default bg-transparent',
    'text-text-primary',
    'hover:bg-surface-tertiary hover:border-border-strong',
    'active:scale-[0.98]',
  ].join(' '),
  ghost: [
    'bg-transparent text-text-link',
    'hover:text-text-link-hover hover:underline underline-offset-4',
  ].join(' '),
};

const sizeClasses: Record<string, string> = {
  sm: 'text-sm px-3 py-1.5 rounded-md',
  md: 'text-sm px-5 py-2.5 rounded-lg',
  lg: 'text-base px-7 py-3 rounded-lg',
};

const Tag = href ? 'a' : 'button';
---

<Tag
  id={id}
  href={href}
  type={!href ? type : undefined}
  class:list={[
    ...baseClasses,
    variantClasses[variant],
    sizeClasses[size],
    className,
  ]}
>
  <slot />
</Tag>
