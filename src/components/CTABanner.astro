---
/**
 * CTABanner — Full-width call-to-action section with gradient background.
 *
 * @prop title - Main headline
 * @prop description - Supporting text
 * @prop primaryCTA - Primary CTA { label, href }
 * @prop secondaryCTA - Optional secondary CTA { label, href }
 * @prop gradient - Gradient style: "hero" | "cta" | "dark"
 */
import Container from './Container.astro';

interface CTALink {
  label: string;
  href: string;
}

interface Props {
  title: string;
  description?: string;
  primaryCTA: CTALink;
  secondaryCTA?: CTALink;
  gradient?: 'hero' | 'cta' | 'dark';
}

const {
  title,
  description,
  primaryCTA,
  secondaryCTA,
  gradient = 'cta',
} = Astro.props;

const gradientClasses: Record<string, string> = {
  hero: 'gradient-hero',
  cta: 'gradient-cta',
  dark: 'gradient-dark-hero',
};
---

<section
  class:list={[
    'relative overflow-hidden py-16 md:py-20',
    gradientClasses[gradient],
  ]}
>
  <Container class="relative z-10">
    <div class="mx-auto max-w-2xl text-center">
      {/* Inline style forces white text — immune to global h2 { color } cascade */}
      <h2
        class="mb-4 font-heading text-3xl leading-tight tracking-tight md:text-4xl"
        style="color: #ffffff;"
      >
        {title}
      </h2>

      {description && (
        <p
          class="mx-auto mb-8 max-w-xl text-base leading-relaxed md:text-lg"
          style="color: rgba(255, 255, 255, 0.85);"
        >
          {description}
        </p>
      )}

      <div class="flex flex-col items-center justify-center gap-4 sm:flex-row">
        {/* Primary CTA: solid white pill with brand text — maximum contrast on gradient */}
        <a
          href={primaryCTA.href}
          class="inline-flex items-center justify-center gap-2
                 rounded-full px-7 py-3 text-base font-body font-semibold
                 bg-white text-brand-600
                 hover:bg-white/90 hover:shadow-lg
                 active:scale-[0.98]
                 transition-all duration-200 ease-default
                 no-underline cursor-pointer"
          style="color: #36157a;"
        >
          {primaryCTA.label}
        </a>

        {secondaryCTA && (
          <a
            href={secondaryCTA.href}
            class="inline-flex items-center justify-center gap-2
                   rounded-full px-7 py-3 text-base font-body font-semibold
                   border border-white/40 bg-transparent
                   hover:bg-white/10 hover:border-white/60
                   active:scale-[0.98]
                   transition-all duration-200 ease-default
                   no-underline cursor-pointer"
            style="color: #ffffff;"
          >
            {secondaryCTA.label}
          </a>
        )}
      </div>
    </div>
  </Container>

  <!-- Decorative background pattern -->
  <div
    class="pointer-events-none absolute inset-0 opacity-10"
    aria-hidden="true"
  >
    <div class="absolute -top-24 -right-24 h-64 w-64 rounded-full bg-white/20 blur-3xl"></div>
    <div class="absolute -bottom-24 -left-24 h-64 w-64 rounded-full bg-white/20 blur-3xl"></div>
  </div>
</section>
