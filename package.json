  "private": true,
  "type": "module",
  "description": "Public website for Vysdom AI — research consultancy and TDI tools.",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "postbuild": "pagefind --site dist/client",
    "preview": "astro preview",
    "check": "astro check",
    "lint": "biome check --write ./src",
    "format": "biome format --write ./src",
    "test": "playwright test",
    "test:visual": "playwright test tests/e2e/visual/",
    "test:a11y": "playwright test tests/e2e/a11y/",
    "test:conversion": "playwright test tests/e2e/conversion/",
    "test:edge": "playwright test tests/e2e/edge-cases/",
    "test:seo": "playwright test tests/seo.spec.ts",
    "lighthouse": "lhci autorun",
    "verify": "bash scripts/verify.sh"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vysdom-ai/vysdomai-website.git"
  },
  "author": "Vysdom AI",
  "license": "UNLICENSED",
  "bugs": {
    "url": "https://github.com/vysdom-ai/vysdomai-website/issues"
  },
  "homepage": "https://vysdom.ai",
  "dependencies": {
    "@astrojs/mdx": "^5.0.3",
    "@astrojs/react": "^5.0.3",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "@astrojs/vercel": "^10.0.4",
    "@gsap/react": "^2.1.2",
    "@pagefind/default-ui": "^1.5.2",
    "@tailwindcss/vite": "^4.2.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "astro": "^6.1.5",
    "cmdk": "^1.1.1",
    "framer-motion": "^12.38.0",
    "gsap": "^3.15.0",
    "katex": "^0.16.45",
    "lenis": "^1.3.21",
    "lite-youtube-embed": "^0.3.4",
    "lucide-react": "^1.8.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "rehype-katex": "^7.0.1",
    "remark-math": "^6.0.0",
    "resend": "^6.11.0",
    "satori": "^0.26.0",
